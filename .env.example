# Local SQLite database. Relative file paths are resolved by the application.
DATABASE_URL="file:./prisma/dev.db"

NODE_ENV="development"
APP_HOST="127.0.0.1"
APP_PORT="3000"
LOG_LEVEL="info"

# Demo Mode is the default and requires no network or API key.
AUDIT_PROVIDER="demo"
DEMO_SEED="agent-auditor-demo-v1"
AUDIT_CONCURRENCY="1"
AUDIT_MAX_TEST_CASES="24"
AUDIT_MAX_DURATION_SECONDS="300"
PROVIDER_TIMEOUT_MS="30000"

# Optional adapter metadata for a future phase. Audit creation remains disabled
# even when both values are present; leave them unset for keyless foundation work.
OPENAI_API_KEY=""
OPENAI_MODEL=""
