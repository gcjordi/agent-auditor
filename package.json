{
  "name": "agent-auditor",
  "version": "0.1.0",
  "private": true,
  "description": "Behavioral security auditing for AI agents in a side-effect-free simulation environment.",
  "license": "Apache-2.0",
  "type": "module",
  "packageManager": "pnpm@11.14.0",
  "engines": {
    "node": ">=24.14.0 <25",
    "pnpm": ">=11.7.0 <12"
  },
  "scripts": {
    "dev": "node scripts/run-next.ts dev --hostname 127.0.0.1 --port 3000",
    "build": "pnpm db:generate && node scripts/run-next.ts build",
    "start": "node scripts/run-next.ts start --hostname 0.0.0.0",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "typecheck": "pnpm db:generate && tsc --noEmit",
    "test": "vitest run --exclude tests/e2e/**",
    "test:unit": "vitest run tests/unit",
    "test:application": "vitest run tests/application",
    "test:integration": "vitest run tests/integration --maxWorkers=1",
    "test:contract": "vitest run tests/contract",
    "test:architecture": "vitest run tests/architecture",
    "test:security": "vitest run tests/security",
    "test:accessibility": "vitest run tests/accessibility",
    "test:e2e": "pnpm build && playwright test",
    "test:coverage": "vitest run --coverage --exclude tests/e2e/**",
    "guard:repository": "tsx scripts/check-repository.ts",
    "licenses:check": "tsx scripts/check-licenses.ts",
    "verify": "pnpm guard:repository && pnpm licenses:check && pnpm db:generate && pnpm format:check && pnpm lint && pnpm typecheck && pnpm test:coverage && pnpm build",
    "db:generate": "prisma generate",
    "db:validate": "prisma validate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:reset": "prisma migrate reset",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@hookform/resolvers": "5.4.0",
    "@prisma/adapter-better-sqlite3": "7.8.0",
    "@prisma/client": "7.8.0",
    "next": "16.2.10",
    "openai": "6.48.0",
    "pino": "10.3.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "7.81.0",
    "server-only": "0.0.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@fast-check/vitest": "0.4.1",
    "@playwright/test": "1.61.1",
    "@tailwindcss/postcss": "4.3.3",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "24.3.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitest/coverage-v8": "4.1.10",
    "axe-core": "4.12.1",
    "better-sqlite3": "12.11.1",
    "dotenv": "17.4.2",
    "eslint": "9.39.5",
    "eslint-config-next": "16.2.10",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-simple-import-sort": "14.0.0",
    "eslint-plugin-unused-imports": "4.4.1",
    "fast-check": "4.9.0",
    "jsdom": "29.1.1",
    "postcss": "8.5.16",
    "prettier": "3.9.5",
    "prisma": "7.8.0",
    "tailwindcss": "4.3.3",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0",
    "vitest": "4.1.10"
  }
}
